{
  "rules": {
    "admins": {
      ".read": "auth != null",
      ".write": false
    },

    "products": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "promoList": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "recommendations": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "settings": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },

    "orders": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$orderId": {
        ".read": "auth != null && (data.child('customerUid').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (newData.child('customerUid').val() === auth.uid || root.child('admins').child(auth.uid).exists())"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
      }
    }
  }
}
