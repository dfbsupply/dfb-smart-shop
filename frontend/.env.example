# Supabase configuration — copy to `.env.local` and fill from the Supabase
# dashboard (Project Settings → API). Both values are PUBLIC-safe (they ship in
# the browser); never put the secret key or service_role key here.

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-publishable-or-anon-key>

# ---------------------------------------------------------------------------
# SERVER-ONLY (no VITE_ prefix → never exposed to the browser). Used by the
# Vercel serverless function api/send-order-email.ts. Set these in the Vercel
# project's Environment Variables, and in a local `.env` (gitignored) if you
# run `vercel dev`. NEVER commit the real key.
# ---------------------------------------------------------------------------

# Resend API key (Sending access). SECRET — store privately, not in chat/git.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where new-order notifications are sent (free tier: must be your Resend signup email).
ORDER_NOTIFICATION_TO=dfbglassandaluminumsupply@proton.me
# From address. Free tier (no verified domain) must use onboarding@resend.dev.
ORDER_EMAIL_FROM=DFB Smart Shop <onboarding@resend.dev>
